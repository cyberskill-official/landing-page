{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberskill.world/schemas/narrative-lines.json",
  "title": "CyberSkill landing-page narration lines (EN + VI)",
  "description": "Per FR-CMS-002 §3.1 (EN) and FR-CMS-003 §3.1 (VI). Voice rules in ../voice-rules.md.",
  "type": "object",
  "required": ["version", "authored_at", "lines"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "authored_at": { "type": "string", "format": "date" },
    "lines": {
      "type": "array",
      "items": { "$ref": "#/$defs/Line" }
    }
  },
  "$defs": {
    "Line": {
      "type": "object",
      "required": ["id", "scene_id", "speaker", "text", "role"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "scene_id": { "type": "string", "enum": ["scene-0", "scene-1", "scene-2", "scene-3", "scene-4", "scene-5", "scene-6", "footer"] },
        "speaker":  { "type": "string", "enum": ["lumi", "company"] },
        "text":     { "type": "string", "minLength": 1 },
        "role":     { "type": "string", "enum": ["primary", "alt-a", "alt-b", "retired"] },
        "word_count":     { "type": "integer", "minimum": 1, "maximum": 30 },
        "syllable_count": { "type": "integer", "minimum": 1, "maximum": 30 },
        "notes":          { "type": "string" },
        "retired_at":     { "type": "string", "format": "date" }
      }
    }
  }
}
