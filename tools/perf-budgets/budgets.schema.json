{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberskill.local/schemas/perf-budgets.schema.json",
  "title": "CyberSkill performance budgets",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "_comment_cwv",
    "cwv",
    "_comment_js_bundle",
    "js_bundle",
    "_comment_page_weight",
    "page_weight",
    "_comment_assets",
    "assets",
    "_comment_draw_calls",
    "draw_calls_per_scene_max"
  ],
  "properties": {
    "$schema": { "const": "./budgets.schema.json" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "_comment_cwv": { "type": "string", "minLength": 1 },
    "_comment_js_bundle": { "type": "string", "minLength": 1 },
    "_comment_page_weight": { "type": "string", "minLength": 1 },
    "_comment_assets": { "type": "string", "minLength": 1 },
    "_comment_draw_calls": { "type": "string", "minLength": 1 },
    "cwv": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lcp_ms_p75", "inp_ms_p75", "cls", "fps_desktop", "fps_mobile"],
      "properties": {
        "lcp_ms_p75": { "$ref": "#/$defs/budgetMetric" },
        "inp_ms_p75": { "$ref": "#/$defs/budgetMetric" },
        "cls": { "$ref": "#/$defs/budgetMetric" },
        "fps_desktop": { "$ref": "#/$defs/budgetMetric" },
        "fps_mobile": { "$ref": "#/$defs/budgetMetric" }
      }
    },
    "js_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["main_chunk_kb_gz"],
      "properties": {
        "main_chunk_kb_gz": { "$ref": "#/$defs/budgetMetric" }
      }
    },
    "page_weight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_scene_mb", "all_scenes_mb"],
      "properties": {
        "first_scene_mb": { "$ref": "#/$defs/budgetMetric" },
        "all_scenes_mb": { "$ref": "#/$defs/budgetMetric" }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lumi_glb_mb", "nonla_glb_kb", "hero_scene_props_mb", "each_scene_props_mb"],
      "properties": {
        "lumi_glb_mb": { "$ref": "#/$defs/budgetMetric" },
        "nonla_glb_kb": { "$ref": "#/$defs/budgetMetric" },
        "hero_scene_props_mb": { "$ref": "#/$defs/budgetMetric" },
        "each_scene_props_mb": { "$ref": "#/$defs/budgetMetric" }
      }
    },
    "draw_calls_per_scene_max": { "$ref": "#/$defs/budgetMetric" }
  },
  "$defs": {
    "budgetMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "fail", "_unit"],
      "properties": {
        "target": { "type": "number" },
        "fail": { "type": "number" },
        "_unit": { "type": "string", "minLength": 1 }
      }
    }
  }
}
