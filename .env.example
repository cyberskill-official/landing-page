# CyberSkill landing page - environment template.
# Copy to .env.local and fill in. NEVER prefix secrets with NEXT_PUBLIC_.
# Everything here is read server-side only (Route Handlers / server components).

# --- Phase 2: Lumi the Genie chat proxy (/api/genie) ---
# The Anthropic API key. Server-side only. The browser never sees it.
ANTHROPIC_API_KEY=

# Pinned model id. Swap without code changes. Haiku is the default for a
# marketing-site Genie (fast + cheap); escalate to a Sonnet id only if answer
# quality on services/portfolio questions is insufficient.
GENIE_MODEL=claude-haiku-4-5-20251001

# Max tokens per Genie reply (the Messages API requires max_tokens every call).
GENIE_MAX_TOKENS=600

# --- Lead routing (/api/lead) ---
# Optional. If unset, leads are logged server-side only (still captured).
# A Slack Incoming Webhook URL for real-time new-lead pings to the team.
LEAD_SLACK_WEBHOOK_URL=
# Optional CRM webhook (HubSpot/Pipedrive/Zapier/n8n) the lead is POSTed to.
LEAD_CRM_WEBHOOK_URL=
# Bearer token for CRM webhook authorization. Server-side only.
LEAD_CRM_TOKEN=

# Resend API Key for emailing lead notifications. Required in production.
RESEND_API_KEY=
# Optional sender address override for lead emails.
LEAD_EMAIL_FROM=
# Optional local storage directory for durable lead saves.
LEAD_STORE_DIR=

# --- Analytics (/api/analytics) ---
# Optional. First-party funnel events (genie_open, lead_submitted, cta_click)
# are logged server-side and, if set, forwarded to this webhook.
ANALYTICS_WEBHOOK_URL=

# --- Public site config (safe to expose) ---
NEXT_PUBLIC_SITE_URL=https://cyberskill.world
# Optional booking calendar URL (https). When set, "Book a 30-minute call" renders
# in contact + thank-you (FR-CTA-005). Leave empty to hide the control.
NEXT_PUBLIC_BOOKING_URL=
# Future: CyberOS content API (FR-OPS-019). Leave empty to use git content modules.
# CYBEROS_CONTENT_URL=
# CYBEROS_CONTENT_TOKEN=

# --- Commissioned Lumi model (FR-CHAR-022) ---
# When set, the hero renders the animated GLB (baked Idle loop) instead of the
# procedural placeholder. Path is relative to /public. Leave unset for the placeholder.
NEXT_PUBLIC_LUMI_GLB=/models/lumi_anim.glb
