{
  "$schema": "./gltf-pipeline.config.schema.json",
  "strategies": [
    { "match": "lumi*.glb", "strategy": "meshopt", "meshoptLevel": "medium" },
    { "match": "lumi*.raw.glb", "strategy": "meshopt", "meshoptLevel": "medium" },
    { "match": "*-rigged.glb", "strategy": "meshopt", "meshoptLevel": "medium" },
    { "match": "scene-*-rigged.glb", "strategy": "meshopt", "meshoptLevel": "medium" },
    { "match": "scene-*-greybox.glb", "strategy": "draco", "dracoMethod": "edgebreaker" },
    { "match": "scene-*-greybox.raw.glb", "strategy": "draco", "dracoMethod": "edgebreaker" },
    { "match": "scene-*-prop.glb", "strategy": "draco", "dracoMethod": "edgebreaker" },
    { "match": "scene-*-prop.raw.glb", "strategy": "draco", "dracoMethod": "edgebreaker" },
    { "match": "footer-greybox.glb", "strategy": "draco", "dracoMethod": "edgebreaker" },
    { "match": "footer-greybox.raw.glb", "strategy": "draco", "dracoMethod": "edgebreaker" },
    { "match": "*-prop.glb", "strategy": "draco", "dracoMethod": "edgebreaker" },
    { "match": "*-prop.raw.glb", "strategy": "draco", "dracoMethod": "edgebreaker" },
    { "match": "static*.glb", "strategy": "draco", "dracoMethod": "edgebreaker" },
    { "match": "*", "strategy": "meshopt", "meshoptLevel": "medium" }
  ],
  "textureCompression": {
    "default": { "format": "webp", "quality": 80 },
    "normalMap": { "format": "ktx2", "mode": "UASTC" },
    "colorMR": { "format": "ktx2", "mode": "ETC1S" },
    "emissive": { "format": "ktx2", "mode": "ETC1S" }
  },
  "prePass": ["dedup", "prune", "weld", "resample"],
  "weldTolerance": 0.0001,
  "earlyWarnPercent": 110,
  "logLevel": "info"
}
