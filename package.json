{
  "name": "cyberskill-landing-page",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm -F web dev",
    "build": "pnpm -F web build && pnpm -F @cyberskill/ds-cinematic build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r test && pnpm test:ci-shape && pnpm test:asset-gates && pnpm test:eslint-rules",
    "test:ci-shape": "vitest run .github/workflows/__tests__/*.test.ts",
    "test:asset-gates": "vitest run tools/perf-budgets/__tests__/*.test.ts tools/perf-budgets/__tests__/*.test.mjs",
    "typecheck": "pnpm -r typecheck",
    "check:p0": "python3 tools/check-p0-frs.py",
    "audit:fr-deliverables": "node tools/audit-fr-deliverables.mjs",
    "regen:p0-assets": "python3 tools/generate-p0-assets.py",
    "check:p1-greybox": "python3 tools/check-p1-greybox-assets.py",
    "gltf-pipeline": "node scripts/gltf-pipeline.mjs",
    "asset-manifest-sync": "node scripts/asset-manifest-sync.mjs",
    "asset-manifest-check": "node scripts/asset-manifest-sync.mjs --check",
    "ktx2-encode": "node scripts/ktx2-encode.mjs",
    "sync-decoders": "node scripts/sync-decoders.mjs",
    "test:budgets": "vitest run tools/perf-budgets/__tests__/budgets-schema.test.ts",
    "test:asset-comment": "vitest run scripts/__tests__/pr-comment-asset-delta.unit.test.mjs",
    "test:asset-manifest": "vitest run scripts/__tests__/asset-manifest-sync.unit.test.mjs",
    "test:gltf-pipeline": "vitest run scripts/__tests__/gltf-pipeline.test.mjs",
    "test:ktx2": "vitest run scripts/__tests__/ktx2-encode.unit.test.mjs",
    "test:sync-decoders": "vitest run scripts/__tests__/sync-decoders.unit.test.mjs",
    "test:eslint-rules": "vitest run eslint-rules/__tests__/*.test.ts eslint-rules/__tests__/*.unit.test.ts",
    "test:lfs-config": "make test-lfs-config",
    "test:cowork-recipe-a": "vitest run tools/cowork/recipes/__tests__/pr-asset-triage.smoke.test.mjs",
    "test:cowork-recipes-bg": "vitest run tools/cowork/recipes/__tests__/recipes-bg.smoke.test.mjs",
    "regen:p1-greybox": "python3 tools/generate-p1-greybox-assets.py",
    "regen:p1-scenes": "python3 tools/generate-p1-scene-assets.py",
    "regen-backlog": "python3 tools/regen-backlog.py",
    "regen-fr-graph": "python3 tools/fr-graph.py",
    "regen-contrast": "python3 design/tokens/contrast-check-script.py"
  },
  "devDependencies": {
    "@gltf-transform/core": "4.3.0",
    "@gltf-transform/extensions": "4.3.0",
    "@gltf-transform/functions": "4.3.0",
    "ajv": "8.17.1",
    "draco3dgltf": "1.5.7",
    "meshoptimizer": "1.1.1",
    "minimatch": "10.2.5",
    "sharp": "0.34.5",
    "typescript": "6.0",
    "vitest": "2.1.9"
  },
  "packageManager": "pnpm@11.1.2"
}
