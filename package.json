{
  "name": "cyberskill-landing-page",
  "version": "0.1.0",
  "private": true,
  "description": "CyberSkill interactive storytelling landing page (Lumi the Golden Genie). Built per the research-foundations PRD/SRS under the CyberOS workflow.",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build --webpack",
    "analyze": "ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify-static.mjs",
    "check:assets": "node scripts/check-asset-size.mjs",
    "check:apca": "node scripts/check-apca.mjs",
    "check:a11y:routes": "node scripts/axe-routes.mjs",
    "test": "vitest run",
    "clean": "rm -rf .next",
    "check:tasks": "node scripts/check-tasks.mjs"
  },
  "dependencies": {
    "@gsap/react": "2.1.2",
    "@hookform/resolvers": "5.4.0",
    "@next/third-parties": "16.2.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@react-three/postprocessing": "3.0.4",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "gsap": "3.15.0",
    "lenis": "1.3.25",
    "next": "16.2.10",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "postprocessing": "6.39.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "three": "0.185.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@next/bundle-analyzer": "16.2.10",
    "@playwright/test": "^1.61.1",
    "@prisma/config": "^7.8.0",
    "@types/node": "26.1.1",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "axe-core": "4.12.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "pdf-parse": "^2.4.5",
    "prisma": "^7.8.0",
    "puppeteer": "25.3.0",
    "svgo": "^4.0.2",
    "typescript": "~6.0.0",
    "vitest": "4.1.10"
  },
  "comments": {
    "progressiveEnhancement": "three / @react-three/* / gsap / lenis power the Phase-3 enhancement only. They are real dependencies (the build compiles the scene chunk), but the chunk is dynamically imported with ssr:false and only mounted on capable desktops with motion allowed, so it never blocks first paint, never ships to mobile/reduced-motion clients, and the crawlable Phase-1 base + Phase-2 chat work without it.",
    "noAnthropicSdk": "The /api/genie proxy calls the Anthropic Messages API with plain fetch + SSE parsing to avoid an SDK version dependency and keep the server bundle small."
  }
}
