{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberskill.local/schemas/asset-manifest.schema.json",
  "title": "CyberSkill source asset manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "assets"],
  "properties": {
    "version": { "const": 1 },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    },
    "assets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "type",
          "sha256",
          "size_bytes",
          "mtime_iso",
          "linked_from",
          "linked_to",
          "latest_built_iso",
          "latest_built_sha256",
          "stale"
        ],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "type": {
            "enum": ["blender", "photoshop", "substance", "figma", "hdri", "after-effects", "other"]
          },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "mtime_iso": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
          },
          "linked_from": {
            "type": "array",
            "items": { "type": "string" }
          },
          "linked_to": {
            "type": "array",
            "items": { "type": "string" }
          },
          "latest_built_iso": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
              },
              { "type": "null" }
            ]
          },
          "latest_built_sha256": {
            "anyOf": [
              { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              { "type": "null" }
            ]
          },
          "stale": { "type": "boolean" }
        }
      }
    }
  }
}
