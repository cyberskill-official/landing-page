{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready in|started server on|Local:",
      "url": [
        "http://localhost:3000/en",
        "http://localhost:3000/vi"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "interactive": ["warn", { "maxNumericValue": 3800 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],
        "categories:performance": ["error", { "minScore": 0.85 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 419840 }],
        "resource-summary:stylesheet:size": ["error", { "maxNumericValue": 61440 }],
        "resource-summary:image:size": ["error", { "maxNumericValue": 409600 }],
        "resource-summary:font:size": ["error", { "maxNumericValue": 143360 }],
        "resource-summary:total:size": ["error", { "maxNumericValue": 1331200 }],
        "resource-summary:third-party:count": ["error", { "maxNumericValue": 10 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
